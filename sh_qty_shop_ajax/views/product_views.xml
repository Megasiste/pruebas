<?xml version="1.0" encoding="utf-8"?>
<odoo>
	
	<!-- INHERIT PRODUCT VIEW FOR MINIMUM ORDER QUANTITY  -->
	
    <record id="sh_product_template_form_view" model="ir.ui.view">
        <field name="name">sh.product.template.form.view</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="multi_website_moq" invisible="1" />
                <field name="sh_increment_qty" invisible="multi_website_moq" />
            </xpath>
            <notebook position="inside">
                <page string="Multi Website MOQ" invisible="not multi_website_moq">
                    <field name="multi_website_ids">
                        <list string="Website wise Qty" editable="bottom">
                            <field name="website_id" required="True" options="{'no_create':True}" domain="[('multi_website_moq','=', True)]" />
                            <field name="sh_increment_qty" />
                        </list>
                    </field>
                </page>
            </notebook>
        </field>
    </record>
    
</odoo>
