<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <!-- Adds a quantity input with +/- buttons on the Shop page (inactive by default) -->
    <template id="products_item_quantity" inherit_id="website_sale.products_item" name="Select Quantity on Shop Page" active="False">
        <xpath expr="//div[hasclass('o_wsale_product_btn')]" position="before">
            <div class="d-flex align-items-center sh-qty-container">
                <div class="css_quantity input-group d-inline-flex align-middle border" contenteditable="false">
                    <a t-attf-href="#" class="css_quantity_minus btn btn-link js_add_cart_json border-0" aria-label="Remove one" title="Remove one"  name="remove_one">
                        <i class="fa fa-minus"></i>
                    </a>
                    <input type="text"
                           class="form-control quantity text-center border-0 sh-shop-qty-input"
                           name="add_qty"
                           data-min="0"
                           t-att-data-increment-qty="product.get_sh_increment_qty() or 1"
                           t-att-data-default-increment="product.get_sh_increment_qty() or 1"
                           value="0"/>
                    <a t-attf-href="#" class="css_quantity_plus btn btn-link js_add_cart_json border-0" aria-label="Add one" title="Add one">
                        <i class="fa fa-plus"></i>
                    </a>
                </div>
            </div>
        </xpath>
    </template>

    <!-- Modifies the quantity input on the Product Detail page -->
    <template id="product_quantity_increment" inherit_id="website_sale.product_quantity">
        <xpath expr="//input[@name='add_qty']" position="attributes">
            <attribute name="t-att-data-min">product.get_sh_increment_qty() or 1</attribute>
            <attribute name="t-att-data-increment-qty">product.get_sh_increment_qty() or 1</attribute>
            <attribute name="t-att-value">product.get_sh_increment_qty() or 1</attribute>
        </xpath>
    </template>

    <!-- Modifies the quantity input on the Shopping Cart page -->
    <template id="cart_lines_quantity_increment" inherit_id="website_sale.cart_lines_quantity">
        <xpath expr="//input[hasclass('js_quantity')]" position="attributes">
            <attribute name="t-att-data-min">line.product_id.get_sh_increment_qty() or 1</attribute>
            <attribute name="t-att-data-increment-qty">line.product_id.get_sh_increment_qty() or 1</attribute>
        </xpath>
    </template>

    <!-- Adds 'Add to Cart' button (Bulk Action) on Shop Page -->
    <template id="products_bulk_add_to_cart_btn" inherit_id="website_sale.products">
        <xpath expr="//header[@id='o_wsale_products_header']//t[@t-call='website_sale.pricelist_list']" position="before">
            <t t-if="is_view_active('sh_qty_shop_ajax_moq.products_item_quantity')">
                <div class="d-flex justify-content-end mb-2 sh-bulk-cart-container">
                    <button class="btn btn-primary sh_bulk_add_to_cart">Add to Cart</button>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
